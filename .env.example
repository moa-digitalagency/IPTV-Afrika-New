# Flask Configuration
FLASK_ENV=development
SECRET_KEY=change-this-in-production

# Database Configuration
DATABASE_URL=postgresql://iptv_user:iptv_password@localhost:5432/iptv_afrika

# GOLDEN API Configuration
GOLDEN_API_BASE_URL=https://api.goldentv.com
GOLDEN_API_KEY=your-api-key-here

# Cache TTL (in seconds)
CACHE_TTL_LINES=900
CACHE_TTL_PACKAGES=3600

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_SECRET_TOKEN=your-secret-token-here

# Rate Limiting
RATELIMIT_STORAGE_URL=memory://

# Initial Superadmin User
SUPERADMIN_USERNAME=admin
SUPERADMIN_EMAIL=admin@moniptvafrica.com
SUPERADMIN_PASSWORD=changeme123456
